# ============================================================
# Regulatory Intelligence Platform — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# ---- Application ----
APP_ENV=local
LOG_LEVEL=INFO
LOG_JSON=false

# ---- Model Gateway ----
MODEL_GATEWAY_MODE=fake              # fake | bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.0

# ---- Kafka / Messaging ----
KAFKA_MODE=memory                    # memory (offline) | aiokafka (real Kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=agents

# ---- MongoDB / State ----
CHECKPOINTER_MODE=memory             # memory | mongodb
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=regintel

# ---- Qdrant / Vector Store ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---- S3 / MinIO ----
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=regintel-artifacts

# ---- Guardrails ----
COMPLIANCE_CONFIDENCE_THRESHOLD=0.8

# ---- GitHub (developer_agent) ----
GITHUB_TOKEN=

# ---- Jira (agile_master_agent) ----
JIRA_BASE_URL=
JIRA_USER=
JIRA_API_TOKEN=

# ---- Ingestion ----
INGESTION_WATCH_PREFIX=uploads/
INGESTION_POLL_INTERVAL_S=30

# ---- Observability ----
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
