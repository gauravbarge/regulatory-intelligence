# Copy to .env for local runs. All values shown are safe local defaults.

APP_ENV=local
LOG_LEVEL=INFO
LOG_JSON=false

# --- Kafka ---
# aiokafka = real broker, memory = in-process bus (no broker needed)
KAFKA_MODE=memory
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=supervisor

# --- Model gateway ---
# bedrock = AWS Bedrock Claude, fake = deterministic offline stub
MODEL_GATEWAY_MODE=fake
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.0

# --- Memory / state ---
# mongodb = LangGraph Mongo checkpointer, memory = in-process saver
CHECKPOINTER_MODE=memory
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=regintel

# --- Vector store (semantic memory) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Artifact store ---
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=regintel-artifacts
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# --- Guardrails ---
COMPLIANCE_CONFIDENCE_THRESHOLD=0.8

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
